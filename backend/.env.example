# Copy this file to .env and fill in your values.
# Never commit .env to Git — it is already in .gitignore.

# ── Required ───────────────────────────────────────────────────────────────────

# Groq API key (free — no credit card needed)
# Get one at: https://console.groq.com → API Keys → Create key
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Gmail address and App Password
# App Password setup (2 min): myaccount.google.com/security → App Passwords
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASS=abcd efgh ijkl mnop

# Your name and role — used to sign draft replies and cold emails
YOUR_NAME=Your Full Name
YOUR_ROLE=Freelance AI Developer

# ── Optional ───────────────────────────────────────────────────────────────────

# SQLite database file path (default: email_agent.db in the backend folder)
DB_FILE=email_agent.db

# How often the agent auto-polls Gmail, in minutes (default: 5)
POLL_INTERVAL=5

# ── Slack alerts (optional) ────────────────────────────────────────────────────

# Slack incoming webhook URL — leave blank to disable all Slack alerts
# Setup: api.slack.com/apps → Create App → Incoming Webhooks → Activate → Add to channel
SLACK_WEBHOOK=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Priority levels that trigger a Slack alert (comma-separated, no spaces)
# Options: high | medium | low
# Default: high only (least noisy)
# Example: SLACK_ALERT_PRIORITIES=high,medium
SLACK_ALERT_PRIORITIES=high

# Email categories that trigger a Slack alert (comma-separated, no spaces)
# Options: lead | client | support | newsletter | spam | other
# Default: lead only
# Example: SLACK_ALERT_CATEGORIES=lead,client
# Leave blank to disable category-based alerts: SLACK_ALERT_CATEGORIES=
SLACK_ALERT_CATEGORIES=lead

# ── CORS (production only) ─────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins
# Default covers the Vercel deployment and local dev — add more if needed
ALLOWED_ORIGINS=https://email-agent-xi-drab.vercel.app,http://localhost:5173
